<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Consulta - Espaço Carol</title>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600&family=Playfair+Display:ital,wght@1,600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>
        :root {
            --lilas-pastel: #E0BBE4;
            --roxo-pastel-medio: #D1B3FF;
            --roxo-pastel-escuro: #B38BFF;
            --off-white: #FDFDFD;
            --branco-puro: #FFFFFF;
        }

        body { font-family: 'Poppins', sans-serif; background: var(--off-white); margin: 0; text-align: center; }

        header {
            position: relative; background-image: url("fundo.jpg");
            background-size: cover; background-position: center;
            padding: 80px 20px; border-bottom: 2px solid var(--lilas-pastel);
        }

        header::after { content: ''; position: absolute; top: 0; left: 0; width: 100%; height: 100%; background-color: rgba(255, 255, 255, 0.7); z-index: 1; }
        header > * { position: relative; z-index: 2; }

        h1 { font-family: 'Playfair Display', serif; font-size: 55px; font-style: italic; color: var(--roxo-pastel-escuro); }

        .search-box { margin: 40px auto; max-width: 500px; background: white; padding: 25px; border-radius: 20px; box-shadow: 0 10px 30px rgba(0,0,0,0.05); }

        input { width: 100%; padding: 15px; border: 1.5px solid #eee; border-radius: 12px; outline: none; margin-bottom: 15px; box-sizing: border-box; }
        
        .btn-busca { background: var(--roxo-pastel-medio); color: white; border: none; padding: 15px 30px; border-radius: 12px; cursor: pointer; font-weight: 700; width: 100%; transition: 0.3s; }
        .btn-busca:hover { background: var(--roxo-pastel-escuro); }

        table { width: 90%; max-width: 1000px; margin: 20px auto; background: white; border-collapse: collapse; border-radius: 15px; overflow: hidden; box-shadow: 0 5px 15px rgba(0,0,0,0.05); }
        th { background: var(--lilas-pastel); color: #555; padding: 15px; }
        td { padding: 15px; border-bottom: 1px solid #eee; }
        .destaque { background-color: #fff4ff; font-weight: bold; }
    </style>
</head>
<body>
    <header>
        <h1>Consulta de Agendamentos</h1>
    </header>

    <div class="search-box">
        <form action="/consulta" method="GET">
            <input type="text" name="cliente" placeholder="Nome da cliente para destacar...">
            <button type="submit" class="btn-busca">Buscar/Atualizar</button>
        </form>
    </div>

    <table>
        <thead>
            <tr>
                <th>Cliente</th>
                <th>Procedimento</th>
                <th>Data</th>
                <th>Hora</th>
            </tr>
        </thead>
        <tbody>
            <% agendamentos.forEach(a => { %>
                <tr class="<%= (clienteBusca && a.nome.toLowerCase().includes(clienteBusca.toLowerCase())) ? 'destaque' : '' %>">
                    <td><%= a.nome %></td>
                    <td><%= a.procedimento %></td>
                    <td><%= a.data %></td>
                    <td><%= a.hora %></td>
                </tr>
            <% }) %>
        </tbody>
    </table>
</body>
</html>