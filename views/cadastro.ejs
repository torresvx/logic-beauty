<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <title>Cadastro - Espaço Beauty</title>
    <style>
        * { box-sizing: border-box; font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; }
        body {
            margin: 0; padding: 0; min-height: 100vh;
            display: flex; justify-content: center; align-items: center;
            background: linear-gradient(135deg, #B76E79, #4A2E35, #F4C2C2);
            color: #F1F1F1;
        }
        .container-vidro {
            background: rgba(255, 255, 255, 0.15); backdrop-filter: blur(15px); -webkit-backdrop-filter: blur(15px);
            border: 1px solid rgba(255, 255, 255, 0.25); border-radius: 20px;
            padding: 40px; width: 100%; max-width: 450px;
            box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.3); position: relative;
        }
        .btn-voltar {
            position: absolute; top: -40px; left: 0;
            color: #F1F1F1; text-decoration: none; font-size: 0.9rem;
            display: flex; align-items: center; gap: 5px; opacity: 0.8;
        }
        .btn-voltar:hover { opacity: 1; text-decoration: underline; color: #B76E79; }
        .logo-text { text-align: center; font-weight: bold; margin-bottom: 20px; font-size: 1.2rem; color: #F1F1F1; }
        h2 { margin: 0 0 20px 0; font-size: 1.5rem; font-weight: 600; color: #F1F1F1; }
        .grupo-input { margin-bottom: 15px; }
        .grupo-input label { display: block; font-size: 0.8rem; margin-bottom: 5px; color: #F1F1F1; }
        .grupo-input input {
            width: 100%; padding: 12px 15px; border: none; border-radius: 8px;
            background: #F1F1F1; color: #4A2E35; outline: none; font-size: 0.9rem;
        }
        .senha-container { position: relative; }
        .btn-olho {
            position: absolute; right: 10px; top: 50%; transform: translateY(-50%);
            background: none; border: none; cursor: pointer; font-size: 1.2rem; color: #4A2E35;
        }
        .linha-dupla { display: flex; gap: 10px; }
        .linha-dupla .grupo-input { flex: 1; }
        .btn-submit {
            width: 100%; padding: 12px; border: none; border-radius: 8px;
            background: #4A2E35; color: #F1F1F1; font-size: 1rem; font-weight: bold;
            cursor: pointer; margin-top: 10px; transition: background 0.3s;
        }
        .btn-submit:hover { background: #B76E79; }
        .links-rodape { text-align: center; margin-top: 20px; font-size: 0.85rem; }
        .links-rodape a { color: #F1F1F1; text-decoration: none; font-weight: bold; margin-left: 5px; }
        .links-rodape a:hover { text-decoration: underline; color: #B76E79; }
</style>
</head>
<body>
    <div class="container-vidro">
        <a href="/" class="btn-voltar">← Voltar para a página inicial</a>
        
        <div class="logo-text">Espaço Beauty</div>
        <h2>Cadastro</h2>
        
        <form action="/cadastrar" method="POST">
            <div class="grupo-input">
                <label for="nomeCadastro">Nome Completo</label>
                <input type="text" id="nomeCadastro" name="nome" placeholder="Digite seu nome" required>
            </div>
            
            <div class="grupo-input">
                <label for="emailCadastro">Email</label>
                <input type="email" id="emailCadastro" name="email" placeholder="seuemail@gmail.com" required>
            </div>
            
            <div class="grupo-input">
                <label for="senhaCadastro">Password</label>
                <div class="senha-container">
                    <input type="password" id="senhaCadastro" name="senha" placeholder="Crie uma senha" required>
                    <button type="button" class="btn-olho" onclick="mostrarSenha('senhaCadastro')">👁️</button>
                </div>
            </div>

            <div class="linha-dupla">
                <div class="grupo-input">
                    <label for="telefoneCadastro">Telefone</label>
                    <input type="text" id="telefoneCadastro" name="telefone" placeholder="(11) 99999-9999" required>
                </div>
                <div class="grupo-input">
                    <label for="dataNascimentoCadastro">Nascimento</label>
                    <input type="date" id="dataNascimentoCadastro" name="data_nascimento" required>
                </div>
            </div>
            
            <button type="submit" class="btn-submit">Registrar</button>
        </form>

        <div class="links-rodape">
            Ja possui conta? <a href="/login">Faça o login aqui!!</a>
        </div>
    </div>

    <script>
        function mostrarSenha(idInput) {
            var input = document.getElementById(idInput);
            if (input.type === "password") {
                input.type = "text";
            } else {
                input.type = "password";
            }
        }
    </script>
</body>
</html>