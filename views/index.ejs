<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Espaço Beauty</title>
    
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
    
    <style>
        :root {
            --primary-dark: #4A2E35;    
            --secondary-light: #F1F1F1; 
            --accent-color: #B76E79;   
            --accent-light: #F4C2C2;    
            --text-main: #4A2E35;       
            --font-main: 'Helvetica Neue', Arial, sans-serif;
        }

        body { font-family: var(--font-main); color: var(--text-main); background-color: var(--secondary-light); }

        /* NAVBAR */
        .navbar { background-color: var(--primary-dark); padding: 1.5rem 2rem; transition: 0.4s; }
        .navbar-brand { font-size: 1.8rem; font-weight: 700; color: #fff !important; letter-spacing: 3px; text-transform: uppercase; }
        .nav-link { color: #fff !important; text-transform: uppercase; font-size: 0.85rem; letter-spacing: 1px; margin: 0 15px; transition: 0.3s; }
        .nav-link:hover { color: var(--accent-light) !important; }
        
        .btn-outline-light {
            border-radius: 0; padding: 10px 25px; text-transform: uppercase; font-size: 0.8rem;
            letter-spacing: 2px; font-weight: 600; border: 1px solid #fff; transition: 0.3s;
        }
        .btn-outline-light:hover { background-color: var(--accent-color); color: #fff; border-color: var(--accent-color); }

        /* HERO SECTION */
        .hero {
            background: linear-gradient(135deg, var(--primary-dark) 0%, var(--accent-color) 100%);
            height: 85vh; display: flex; align-items: center; justify-content: center; text-align: center; color: #fff;
            padding-top: 100px;
        }
        .hero h1 { font-size: clamp(3rem, 5vw, 5rem); font-weight: 300; margin-bottom: 20px; line-height: 1.1; letter-spacing: 1px; max-width: 900px; }
        .hero p { font-size: 1.2rem; font-weight: 300; letter-spacing: 2px; margin-bottom: 40px; color: var(--accent-light); }

        /* TÍTULOS DE SECÇÃO */
        .section-title { text-align: center; font-size: 2.5rem; font-weight: bold; margin-bottom: 4rem; text-transform: uppercase; letter-spacing: 3px; color: var(--primary-dark); }

        /* SERVICES */
        .services-section { padding: 120px 0; background-color: #fff; }
        .service-card { padding: 50px 40px; border: 1px solid #eee; height: 100%; transition: all 0.4s ease; cursor: default; background: var(--secondary-light); }
        .service-card:hover { background-color: var(--primary-dark); color: #fff; box-shadow: 0 20px 40px rgba(74,46,53,0.15); transform: translateY(-5px); }
        .service-card h3 { font-size: 1.5rem; font-weight: bold; margin-bottom: 20px; text-transform: uppercase; letter-spacing: 1px; color: var(--accent-color); }
        .service-card:hover h3 { color: var(--accent-light); }
        .service-card p { font-size: 0.95rem; line-height: 1.7; opacity: 0.9; }

        /* ABOUT */
        .about-section { padding: 120px 0; background-color: var(--secondary-light); }
        .about-text h2 { font-size: 3rem; font-weight: 300; margin-bottom: 30px; line-height: 1.2; color: var(--primary-dark); }
        .about-text p { font-size: 1.1rem; line-height: 1.8; color: #555; margin-bottom: 20px; }
        .css-image-placeholder {
            width: 100%; height: 600px; background: linear-gradient(45deg, var(--accent-color), var(--accent-light));
            display: flex; align-items: center; justify-content: center;
            color: #fff; font-size: 2rem; font-weight: 700; letter-spacing: 5px; text-transform: uppercase;
        }

        /* REVIEWS */
        .reviews-section { padding: 120px 0; background-color: #fff; }
        .review-box { background-color: var(--secondary-light); padding: 50px; height: 100%; border-top: 4px solid var(--accent-color); }
        .stars { color: var(--accent-color); margin-bottom: 20px; font-size: 1.2rem; }
        .review-text { font-size: 1.05rem; line-height: 1.8; font-style: italic; margin-bottom: 30px; }
        .review-author { font-weight: 700; text-transform: uppercase; letter-spacing: 1px; font-size: 0.9rem; color: var(--primary-dark); }

        /* =========================================
           SESSÃO DA EQUIPE
           ========================================= */
        /* O valor 100px 0 aplica espaço em cima e EMBAIXO da seção */
        .team-section { padding: 100px 0; background-color: var(--secondary-light); }
        .team-section .section-title { color: var(--primary-dark); margin-bottom: 3rem; }
        
        .team-card {
            position: relative;
            aspect-ratio: 3/4;
            background-size: cover;
            background-position: center;
            overflow: hidden;
            display: flex;
            align-items: flex-end;
            justify-content: center;
            padding: 40px 20px;
            text-align: center;
            cursor: pointer;
        }
        .team-card::before {
            content: '';
            position: absolute;
            top: 0; left: 0; right: 0; bottom: 0;
            background: linear-gradient(to top, rgba(0,0,0,0.85) 0%, rgba(0,0,0,0) 60%);
            transition: 0.4s;
        }
        .team-card:hover::before {
            background: linear-gradient(to top, rgba(0,0,0,0.95) 0%, rgba(0,0,0,0.3) 60%);
        }
        .team-info {
            position: relative;
            z-index: 1;
            color: #fff;
            transition: transform 0.4s;
        }
        .team-card:hover .team-info {
            transform: translateY(-10px);
        }
        .team-info p {
            font-family: Georgia, serif;
            font-size: 0.9rem;
            font-style: italic;
            margin-bottom: 8px;
            color: #e2e2e2;
        }
        .team-info h4 {
            font-size: 1.15rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 2px;
            margin: 0;
            color: #fff;
        }

        /* FOOTER */
        footer { background-color: var(--primary-dark); color: #fff; padding: 100px 0 40px; border-top: 1px solid var(--accent-color); }
        .footer-logo { font-size: 2.5rem; font-weight: 700; letter-spacing: 4px; margin-bottom: 30px; text-transform: uppercase; color: var(--accent-light); }
        .footer-links h5 { font-size: 0.9rem; text-transform: uppercase; letter-spacing: 2px; margin-bottom: 25px; color: var(--accent-light); }
        .footer-links a { color: #ddd; text-decoration: none; display: block; margin-bottom: 15px; transition: 0.3s; font-size: 0.9rem; }
        .footer-links a:hover { color: #fff; padding-left: 5px; }
        
        .newsletter input { background: transparent; border: none; border-bottom: 1px solid var(--accent-color); color: #fff; border-radius: 0; padding: 15px 0; width: 100%; margin-bottom: 20px; outline: none; }
        .newsletter input:focus { border-color: #fff; }
        .newsletter button { background: var(--accent-color); border: none; color: #fff; padding: 10px 20px; text-transform: uppercase; font-size: 0.8rem; letter-spacing: 2px; transition: 0.3s; font-weight: bold; }
        .newsletter button:hover { background: #fff; color: var(--primary-dark); }
        
        .footer-bottom { margin-top: 80px; padding-top: 30px; border-top: 1px solid var(--accent-color); text-align: center; color: #ddd; font-size: 0.85rem; }
    </style>
</head>
<body>

    <nav class="navbar navbar-expand-lg fixed-top">
