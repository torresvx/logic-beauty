<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <title>Meus Agendamentos</title>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;600&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Poppins', sans-serif; background: #f4f4f4; text-align: center; }
        .container { max-width: 500px; margin: 50px auto; background: white; padding: 30px; border-radius: 15px; border-top: 5px solid #ff6f91; }
        .card { background: #fff0f3; padding: 15px; margin-bottom: 15px; border-radius: 8px; text-align: left; border-left: 5px solid #ff6f91; }
    </style>
</head>
<body>
    <div class="container">
        <h1>Olá, <%= nome_logado %>! ✨</h1>
        <a href="/logout" style="color: #ff6f91; text-decoration: none; font-weight: 600;">Sair da conta</a>

        <h3 style="margin-top: 30px;">Seus Próximos Horários:</h3>

        <% if(agendamentos.length > 0) { %>
            <% agendamentos.forEach(row => { %>
                <div class="card">
                    <strong>Data:</strong> <%= new Date(row.data).toLocaleDateString('pt-BR') %><br>
                    <strong>Hora:</strong> <%= row.hora %><br>
                    <strong>Serviços:</strong> <%= row.procedimento %>
                </div>
            <% }) %>
        <% } else { %>
            <p>Você ainda não tem agendamentos marcados.</p>
        <% } %>

        <a href="/" style="display: block; margin-top: 20px; color: #888;">Voltar ao Início</a>
    </div>
</body>
</html>