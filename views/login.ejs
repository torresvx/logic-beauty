<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <title>Acesso - Logic Beauty</title>
    <link href="https://fonts.googleapis.com/css2?family=Great+Vibes&family=Poppins:wght@400;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    
    <style>
        body {
            font-family: 'Poppins', sans-serif;
            background: #f4f4f4; 
            text-align: center;
            margin: 0;
            color: #333;
        }

        header {
            background-image: url("/landing img.jpg"); 
            background-size: cover;
            background-position: center;
            padding: 60px 40px;
            border-bottom: 3px solid #ff6f91;
            margin-bottom: 40px;
        }

        h1 {
            font-family: 'Great Vibes', cursive;
            font-size: 70px;
            color: black; 
            font-weight: bold;
            margin: 0;
            text-shadow: 2px 2px 0px rgba(255, 111, 145, 0.3); 
        }

        .container {
            display: flex;
            justify-content: center;
            gap: 40px;
            flex-wrap: wrap;
            padding: 0 20px;
            margin-bottom: 30px;
        }

        .box {
            background: white;
            padding: 30px;
            border-radius: 15px;
            box-shadow: 0 10px 25px rgba(0,0,0,0.05); 
            width: 320px;
            border-top: 4px solid #ff6f91; 
        }

        h2 {
            color: #ff6f91;
            margin-top: 0;
        }

        .input-container {
            position: relative;
            margin: 15px 0;
            text-align: left;
        }

        .input-container i.main-icon {
            position: absolute;
            left: 12px;
            top: 50%;
            transform: translateY(-50%);
            color: #ff6f91; 
            font-size: 18px;
        }

        .btn-eye {
            position: absolute;
            right: 12px;
            top: 50%;
            transform: translateY(-50%);
            cursor: pointer;
            color: #888;
            transition: 0.3s;
        }

        .btn-eye:hover {
            color: #ff6f91;
        }

        input {
            width: 100%;
            padding: 12px 12px 12px 40px; 
            border: 1px solid #ddd;
            border-radius: 8px;
            font-family: 'Poppins', sans-serif;
            box-sizing: border-box;
            transition: 0.3s;
        }

        input:focus {
            border-color: #ff6f91;
            outline: none;
            box-shadow: 0 0 5px rgba(255, 111, 145, 0.3);
        }

        button {
            padding: 12px;
            border: none;
            background: #ff6f91;
            color: white;
            border-radius: 8px;
            cursor: pointer;
            font-weight: 600;
            width: 100%;
            font-size: 16px;
            margin-top: 10px;
            transition: 0.3s;
        }

        button:hover {
            background: #ff4d73; 
        }

        .msg {
            margin: 20px auto;
            padding: 10px 20px;
            display: inline-block;
            background: white;
            border-radius: 20px;
            font-weight: 600;
            color: #ff4d73; 
            box-shadow: 0 4px 10px rgba(0,0,0,0.05);
        }

        .back-link {
            display: inline-block;
            margin-top: 20px;
            color: #888;
            text-decoration: none;
            font-size: 14px;
            transition: 0.3s;
        }

        .back-link:hover {
            color: #ff6f91;
        }
    </style>
</head>
<body>

    <header>
        <h1>Logic Beauty</h1>
    </header>

    <% if(msg != "") { %>
        <div class="msg"><%= msg %></div>
    <% } %>

    <div class="container">
        
        <div class="box">
            <h2>Login</h2>
            <form action="/login" method="POST">
                <div class="input-container">
                    <i class="fa-solid fa-user main-icon"></i>
                    <input type="email" name="usuario" placeholder="Seu E-mail" required>
                </div>
                <div class="input-container">
                    <i class="fa-solid fa-lock main-icon"></i>
                    <input type="password" name="senha" id="passLogin" placeholder="Sua Senha" required>
                    <i class="fa-solid fa-eye btn-eye" onclick="togglePass('passLogin', this)"></i>
                </div>
                <button type="submit">Entrar no Sistema</button>
            </form>
        </div>

        <div class="box">
            <h2>Novo Cliente</h2>
            <form action="/cadastrar" method="POST">
                <div class="input-container">
                    <i class="fa-solid fa-signature main-icon"></i>
                    <input type="text" name="nome" placeholder="Nome Completo" required>
                </div>
                <div class="input-container">
                    <i class="fa-solid fa-at main-icon"></i>
                    <input type="email" name="usuario" placeholder="Seu melhor e-mail" required>
                </div>
                <div class="input-container">
                    <i class="fa-solid fa-phone main-icon"></i>
                    <input type="text" name="telefone" placeholder="Telefone (DDD)" required>
                </div>
                <div class="input-container">
                    <i class="fa-solid fa-cake-candles main-icon"></i>
                    <input type="date" name="data_nascimento" required title="Data de Nascimento">
                </div>
                <div class="input-container">
                    <i class="fa-solid fa-key main-icon"></i>
                    <input type="password" name="senha" id="passCad" placeholder="Crie uma Senha" required>
                    <i class="fa-solid fa-eye btn-eye" onclick="togglePass('passCad', this)"></i>
                </div>
                <button type="submit" style="background: #333;">Criar Minha Conta</button>
            </form>
        </div>
    </div>

    <a href="/" class="back-link">
        <i class="fa-solid fa-arrow-left"></i> Voltar para o Início
    </a>

    <script>
        function togglePass(id, icone) {
            const input = document.getElementById(id);
            if (input.type === "password") {
                input.type = "text";
                icone.classList.replace("fa-eye", "fa-eye-slash");
            } else {
                input.type = "password";
                icone.classList.replace("fa-eye-slash", "fa-eye");
            }
        }
    </script>

</body>
</html>