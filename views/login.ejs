                    <input type="email" id="emailRecuperar" name="email" placeholder="seuemail@gmail.com" required>
                </div>
                
                <button type="submit" class="btn-submit">Enviar E-mail</button>
            </form>

            <div class="links-rodape">
                <button type="button" onclick="trocarFormulario('caixa-login')" class="btn-como-link">Voltar para o Login</button>
            </div>
        </div>

    </div>

    <script>
        function mostrarSenha(idInput) {
            var input = document.getElementById(idInput);
            if (input.type === "password") {
                input.type = "text";
            } else {
                input.type = "password";
            }
        }

        function trocarFormulario(idMostrar) {
            document.querySelectorAll('.form-box').forEach(div => div.classList.remove('active'));
            document.getElementById(idMostrar).classList.add('active');
        }
    </script>
