<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <title>Login - Espaço Beauty</title>
    <style>
        * { box-sizing: border-box; font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; }
        body {
            margin: 0; padding: 0; min-height: 100vh;
            display: flex; justify-content: center; align-items: center;
            background: linear-gradient(135deg, #B76E79, #4A2E35, #F4C2C2);
            color: #F1F1F1; 
        }
        .container-vidro {
            background: rgba(255, 255, 255, 0.15); backdrop-filter: blur(15px); -webkit-backdrop-filter: blur(15px);
            border: 1px solid rgba(255, 255, 255, 0.25); border-radius: 20px;
            padding: 40px; width: 100%; max-width: 400px;
            box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.3); position: relative;
        }
        .btn-voltar {
            position: absolute; top: -40px; left: 0;
            color: #F1F1F1; text-decoration: none; font-size: 0.9rem;
            display: flex; align-items: center; gap: 5px; opacity: 0.8;
        }
        .btn-voltar:hover { opacity: 1; text-decoration: underline; }
        
        .logo-text { text-align: center; font-weight: bold; margin-bottom: 20px; font-size: 1.2rem; color: #F1F1F1; }
        h2 { margin: 0 0 20px 0; font-size: 1.5rem; font-weight: 600; color: #F1F1F1; }
        
        .grupo-input { margin-bottom: 15px; }
        .grupo-input label { display: block; font-size: 0.8rem; margin-bottom: 5px; color: #F1F1F1; }
        .grupo-input input {
            width: 100%; padding: 12px 15px; border: none; border-radius: 8px;
            background: #F1F1F1; color: #4A2E35; outline: none; font-size: 0.9rem; /* Fundo cinza claro e texto em Roxo Aralendo */
        }
        .senha-container { position: relative; }
        .btn-olho {
            position: absolute; right: 10px; top: 50%; transform: translateY(-50%);
            background: none; border: none; cursor: pointer; font-size: 1.2rem; color: #4A2E35;
        }
        
        .btn-submit {
            width: 100%; padding: 12px; border: none; border-radius: 8px;
            background: #4A2E35; color: #F1F1F1; font-size: 1rem; font-weight: bold; cursor: pointer;
            margin-top: 15px; transition: background 0.3s;
        }
        .btn-submit:hover { background: #B76E79; } 
        
        .links-rodape { text-align: center; margin-top: 20px; font-size: 0.85rem; }
        .links-rodape a { color: #F1F1F1; text-decoration: none; font-weight: bold; }
        .links-rodape a:hover { text-decoration: underline; color: #B76E79; }
        
        .btn-como-link {
            background: none; border: none; color: #F1F1F1; cursor: pointer;
            font-weight: bold; text-decoration: none; padding: 0; font-family: inherit; font-size: inherit;
        }
        .btn-como-link:hover { text-decoration: underline; color: #B76E79; }
        .link-esqueceu { display: block; text-align: right; font-size: 0.8rem; margin-top: -5px; margin-bottom: 10px; width: 100%; }

        .form-box { display: none; }
        .active { display: block; }
</style>
</head>
<body>
    <div class="container-vidro">
        <a href="/" class="btn-voltar">← Voltar para a página inicial</a>
        <div class="logo-text">Espaço Beauty</div>
        
        <!-- CAIXA DE LOGIN -->
        <div id="caixa-login" class="form-box active">
            <h2>Login</h2>
            <form action="/login" method="POST">
                <div class="grupo-input">
                    <label for="emailLogin">Email</label>
                    <input type="email" id="emailLogin" name="email" placeholder="seuemail@gmail.com" required>
                </div>
                
                <div class="grupo-input">
                    <label for="senhaLogin">Password</label>
                    <div class="senha-container">
                        <input type="password" id="senhaLogin" name="senha" placeholder="Sua senha" required>
                        <button type="button" class="btn-olho" onclick="mostrarSenha('senhaLogin')">👁️</button>
                    </div>
                </div>
                
                <button type="button" onclick="trocarFormulario('caixa-recuperar')" class="btn-como-link link-esqueceu">Forgot Password?</button>
                
                <button type="submit" class="btn-submit">Sign in</button>
            </form>

            <div class="links-rodape">
                Não possui conta ainda? <a href="/cadastro">Cadastre-se de graça</a>
            </div>
        </div>

        <!-- CAIXA DE RECUPERAÇÃO DE SENHA -->
        <div id="caixa-recuperar" class="form-box">
            <h2>Recuperar Senha</h2>
            <p style="font-size: 0.85rem; color: rgba(255,255,255,0.8); margin-bottom: 20px;">
                Digite seu e-mail cadastrado e enviaremos um link para redefinir sua senha.
            </p>
            <form action="/recuperar-senha" method="POST">
                <div class="grupo-input">
                    <label for="emailRecuperar">Email</label>
                    <input type="email" id="emailRecuperar" name="email" placeholder="seuemail@gmail.com" required>
                </div>
                
                <button type="submit" class="btn-submit">Enviar E-mail</button>
            </form>

            <div class="links-rodape">
                <button type="button" onclick="trocarFormulario('caixa-login')" class="btn-como-link">Voltar para o Login</button>
            </div>
        </div>

    </div>

    <script>
        function mostrarSenha(idInput) {
            var input = document.getElementById(idInput);
            if (input.type === "password") {
                input.type = "text";
            } else {
                input.type = "password";
            }
        }

        function trocarFormulario(idMostrar) {
            document.querySelectorAll('.form-box').forEach(div => div.classList.remove('active'));
            document.getElementById(idMostrar).classList.add('active');
        }
    </script>
</body>
</html>